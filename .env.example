# ASD-KGRAG local configuration template.
# Copy this file to .env and fill secrets locally. Do not commit .env.

# OpenAI-compatible chat completion endpoint.
LLM_BASE_URL="https://api.siliconflow.cn/v1/chat/completions"
LLM_API_KEY="replace-with-your-api-key"
LLM_MODEL="deepseek-ai/DeepSeek-V4-Flash"
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=1
QA_LLM_MAX_TOKENS=1200

# Neo4j local Docker defaults.
NEO4J_URL="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASS="asd-kgrag-local"

# Qdrant local Docker defaults.
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="asd_kgrag_chunks"
QDRANT_API_KEY=""

# Embedding model used by the current Qdrant collection.
EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"
