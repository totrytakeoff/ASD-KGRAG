FROM python:3.12-slim

WORKDIR /app

COPY wheels/ /wheels/
COPY requirements-qa.deploy.txt .
RUN pip install --no-cache-dir --no-index --find-links=/wheels "torch==2.7.1+cpu" \
 && pip install --no-cache-dir --no-index --find-links=/wheels -r requirements-qa.deploy.txt

COPY scripts/ scripts/
COPY config/ config/

EXPOSE 8010

CMD ["python", "scripts/qa/kgrag_api.py", "--host", "0.0.0.0"]
